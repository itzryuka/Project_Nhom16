@model IEnumerable<BAO_Cinemas.Models.Showtime>
@*
    Model: Danh sách các suất chiếu (Showtime) của một bộ phim cụ thể.
    Dữ liệu này được sử dụng để đổ vào bảng danh sách phía dưới.
*@

@{
    var movie = ViewBag.MovieInfo as BAO_Cinemas.Models.Movie;
    // Cài đặt Title cho trang webx
    ViewData["Title"] = $"Lịch Chiếu: {movie?.Title}";
}

<div class="container-fluid bg-dark text-white p-4 mt-4 rounded shadow">
    @* --- PHẦN TIÊU ĐỀ: Hiển thị tên phim đang xem lịch --- *@
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <h2 class="fw-bold text-warning m-0">
            <i class="bi bi-clock-history"></i> Lịch Chiếu: <span class="text-info">@movie?.Title</span>
        </h2>

        <div>
            @* Nút quay lại danh sách quản lý lịch chiếu tổng quát *@
            <a asp-action="Showtime" class="btn btn-outline-light">
                <i class="bi bi-arrow-left"></i> Về Danh sách Phim
            </a>
        </div>
    </div>

    @* --- HỆ THỐNG THÔNG BÁO (ALERTS) --- *@
    @* Hiển thị thông báo nếu có lỗi xảy ra (ví dụ: không thể xóa suất chiếu đã có người đặt vé) *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-bold" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @* Hiển thị thông báo thành công khi cập nhật hoặc xóa suất chiếu thành công *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* --- BẢNG CHI TIẾT CÁC SUẤT CHIẾU --- *@
    <div class="table-responsive">
        <table class="table table-dark table-hover table-bordered align-middle text-center">
            <thead class="table-secondary text-dark">
                <tr>
                    <th style="width: 15%;">Ngày chiếu</th>
                    <th style="width: 15%;">Khung giờ</th>
                    <th style="width: 25%;">Địa điểm (Rạp - Phòng)</th>
                    <th style="width: 15%;">Giá vé</th>
                    <th style="width: 15%;">Tình trạng ghế</th>
                    <th style="width: 15%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-5">
                            <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                            Phim này đã hết lịch chiếu.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>