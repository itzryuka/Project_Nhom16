@* Khai báo kiểu dữ liệu của đối tượng truyền từ Controller sang View là class Room *@
@model Room
@* Model này đại diện cho đối tượng Phòng Chiếu (Room) cần chỉnh sửa *@

@{
    ViewData["Title"] = "Sửa Phòng Chiếu";
}

@* Container chính: Dùng màu nền tối (bg-dark), chữ trắng (text-white) và bo góc để tạo giao diện hiện đại *@
<div class="container bg-dark text-white p-4 mt-4 rounded shadow" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <h2 class="fw-bold text-info m-0">Sửa: @Model.Name</h2>
        <a asp-action="RoomList" asp-route-cinemaId="@Model.CinemaId" class="btn btn-outline-light">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <form asp-action="EditRoom" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CinemaId" />

        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold">Tên Phòng <span class="text-danger">*</span></label>
            @* asp-for: Tự động liên kết (binding) với thuộc tính Name trong Model Room *@
            <input asp-for="Name" class="form-control bg-secondary text-white border-0" required />
            @* Hiển thị thông báo lỗi riêng cho trường Name *@
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TotalSeats" class="form-label fw-bold">Số lượng ghế</label>
            <input asp-for="TotalSeats" type="number" class="form-control bg-secondary text-white border-0" />
        </div>

        <div class="mb-4">
            <label asp-for="Status" class="form-label fw-bold">Trạng thái hoạt động</label>
            <select asp-for="Status" class="form-select bg-secondary text-white border-0">
                <option value="1">Đang hoạt động</option>
                <option value="2">Đang bảo trì</option>
                <option value="3">Dừng hoạt động</option>
            </select>
        </div>

        <div class="text-end border-top border-secondary pt-3">
            <button type="submit" class="btn btn-info fw-bold px-4 py-2 text-dark">
                <i class="bi bi-check-circle"></i> Cập nhật Thông Tin
            </button>
        </div>
    </form>
</div>

@* Phần script để kiểm tra dữ liệu ngay tại trình duyệt (Client-side validation) *@
@section Scripts {
    @* Script hỗ trợ kiểm tra dữ liệu ngay tại trình duyệt (Client-side validation)
       giúp báo lỗi ngay mà không cần tải lại trang *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}