@{
    ViewData["Title"] = "Thống Kê Doanh Thu";

    // Ép kiểu dữ liệu từ ViewBag (được truyền từ Controller) về đúng danh sách Model tương ứng.
    // Điều này giúp Visual Studio có thể gợi ý code (IntelliSense) trong vòng lặp ở dưới.
    var movieTable = ViewBag.MovieTable as List<BAO_Cinemas.Controllers.MovieRevVM>;
    var dateTable = ViewBag.DateTable as List<BAO_Cinemas.Controllers.DailyRevVM>;
}

<div class="container-fluid mt-4 mb-5">

    @* --- PHẦN HEADER: TIÊU ĐỀ, BỘ LỌC VÀ TỔNG DOANH THU --- *@
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <h2 class="text-warning fw-bold mb-0"><i class="bi bi-bar-chart-fill"></i> DOANH THU</h2>

        @* Bộ lọc tháng: Sử dụng Form GET *@
        <form method="get" asp-action="RevenueReport" class="d-flex align-items-center gap-2">
            <label class="text-light fw-bold text-nowrap">Chọn tháng:</label>
            @*
               onchange="this.form.submit()": Mẹo UX rất hay. 
               Ngay khi người dùng chọn tháng khác, form sẽ tự động gửi request lên Server 
               mà không cần phải bấm thêm nút "Tìm kiếm/Lọc".
            *@
            <input type="month" name="selectedMonth" value="@ViewBag.SelectedMonth" class="form-control bg-dark text-white border-secondary" onchange="this.form.submit()" />
        </form>

        @* Hiển thị Tổng doanh thu. Hàm .ToString("N0") giúp định dạng số có dấu phẩy phân cách hàng nghìn (VD: 1,500,000) *@
        <h3 class="text-success fw-bold mb-0">Tổng: @ViewBag.TotalRevenue.ToString("N0") đ</h3>
    </div>

    @* --- PHẦN KIỂM TRA DỮ LIỆU (EMPTY STATE) --- *@
    @if (movieTable == null || movieTable.Count == 0)
    {
        <div class="alert alert-warning text-center fw-bold">
            Không có dữ liệu doanh thu nào trong tháng @ViewBag.SelectedMonth!
        </div>
    }
    else
    {
        @* Khung chia đôi màn hình: Cột trái cho Phim, Cột phải cho Ngày *@
        <div class="row">

            @* =========================================
               CỘT TRÁI: THỐNG KÊ THEO TỪNG BỘ PHIM
               ========================================= *@
            <div class="col-md-6 mb-4">

                @* 1. Phần Biểu đồ Phim *@
                <div class="card bg-dark border-secondary shadow mb-3">
                    <div class="card-header border-secondary">
                        <h5 class="text-info fw-bold mb-0">DOANH THU THEO PHIM</h5>
                    </div>
                    <div class="card-body">
                        @* Thẻ canvas là nơi Chart.js sẽ "vẽ" biểu đồ vào. ID phải là duy nhất. *@
                        <canvas id="movieChart" style="max-height: 300px;"></canvas>
                    </div>
                </div>

                @* 2. Phần Bảng dữ liệu Phim *@
                <div class="table-responsive">
                    <table class="table table-dark table-hover table-bordered text-center align-middle">
                        <thead class="table-info text-dark">
                            <tr>
                                <th class="text-start">Tên Phim</th>
                                <th>Số vé bán</th>
                                <th>Doanh Thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @* Lặp qua danh sách phim để tạo các hàng (tr) cho bảng *@
                            @foreach (var item in movieTable)
                            {
                                <tr>
                                    <td class="text-start text-info fw-bold">@item.MovieName</td>
                                    <td>@item.TicketsSold vé</td>
                                    <td class="text-success fw-bold">@item.Revenue.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* =========================================
               CỘT PHẢI: THỐNG KÊ BIẾN ĐỘNG THEO NGÀY
               ========================================= *@
            <div class="col-md-6 mb-4">

                @* 1. Phần Biểu đồ Ngày *@
                <div class="card bg-dark border-secondary shadow mb-3">
                    <div class="card-header border-secondary">
                        <h5 class="text-danger fw-bold mb-0">BIẾN ĐỘNG THEO NGÀY</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="dateChart" style="max-height: 300px;"></canvas>
                    </div>
                </div>

                @* 2. Phần Bảng dữ liệu Ngày *@
                <div class="table-responsive">
                    <table class="table table-dark table-hover table-bordered text-center align-middle">
                        <thead class="table-danger text-dark">
                            <tr>
                                <th class="text-start">Ngày ghi nhận</th>
                                <th>Doanh Thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in dateTable)
                            {
                                <tr>
                                    <td class="text-start text-light">@item.DateString</td>
                                    <td class="text-success fw-bold">@item.Revenue.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    }
</div>

@* Nhúng thư viện Chart.js qua CDN *@
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // Chạy script sau khi toàn bộ HTML đã được tải xong (tránh việc tìm ID canvas bị lỗi null)
    document.addEventListener("DOMContentLoaded", function () {
        
        // CỰC KỲ QUAN TRỌNG: #Html.Raw()
        // ViewBag chứa chuỗi JSON (ví dụ: "['Phim A', 'Phim B']").
        // Nếu không có Html.Raw, C# sẽ tự động mã hóa chuỗi này thành HTML an toàn (vd: dấu ' thành &#39;), làm JS bị lỗi cú pháp.
        const movieLabelsCheck = @Html.Raw(ViewBag.MovieLabels ?? "[]");

        // Chỉ khởi tạo Chart.js nếu mảng nhãn có chứa dữ liệu
        if (movieLabelsCheck.length > 0) {

            const movieLabels = @Html.Raw(ViewBag.MovieLabels);
            const movieData = @Html.Raw(ViewBag.MovieData);
            const dateLabels = @Html.Raw(ViewBag.DateLabels);
            const dateData = @Html.Raw(ViewBag.DateData);

        // 1. Khởi tạo Biểu đồ Cột (Bar Chart) cho Doanh thu Phim
            new Chart(document.getElementById('movieChart'), {
                type: 'bar', // Dạng cột đứng
                data: {
                    labels: movieLabels, // Tên các bộ phim (trục X)
                    datasets: [{
                        label: 'Doanh thu',
                        data: movieData, // Doanh thu tương ứng (trục Y)
                        backgroundColor: 'rgba(13, 202, 240, 0.7)', // Màu cột (màu Info của Bootstrap, hơi trong suốt)
                        borderColor: 'rgba(13, 202, 240, 1)',
                        borderWidth: 1
                    }]
                },
                // Tắt ô chú thích (legend) vì chỉ có 1 cột dữ liệu, không cần thiết
                options: { plugins: { legend: { display: false } } }
            });

            // 2. Khởi tạo Biểu đồ Đường (Line Chart) cho Biến động theo Ngày
            new Chart(document.getElementById('dateChart'), {
                type: 'line', // Dạng đường kẻ nối các điểm
                data: {
                    labels: dateLabels, // Các ngày trong tháng (trục X)
                    datasets: [{
                        label: 'Doanh thu',
                        data: dateData, // Doanh thu theo ngày (trục Y)
                        backgroundColor: 'rgba(220, 53, 69, 0.2)', // Màu nền dưới đường kẻ (màu Danger của Bootstrap)
                        borderColor: 'rgba(220, 53, 69, 1)', // Màu đường kẻ
                        borderWidth: 2,
                        fill: true, // Tô màu khu vực bên dưới đường kẻ tạo hiệu ứng vùng (Area chart)
                        tension: 0.3 // Làm cong các góc nối (thay vì nối thẳng tắp, đường kẻ sẽ uốn lượn mượt mà hơn)
                    }]
                },
                options: { plugins: { legend: { display: false } } }
            });
        }
    });
</script>