@* Khai báo Model: Nhận vào danh sách các đối tượng Room thuộc về rạp đang chọn *@
@model IEnumerable<Room>

@{
    // Lấy thông tin Rạp từ Controller gửi sang để làm tiêu đề
    var cinema = ViewBag.CinemaInfo as BAO_Cinemas.Models.Cinema;
    ViewData["Title"] = $"Danh sách Phòng - {cinema?.Name}";
}

<div class="container-fluid bg-dark text-white p-4 mt-4 rounded shadow">
    @* --- PHẦN HEADER: TIÊU ĐỀ VÀ NÚT ĐIỀU HƯỚNG --- *@
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <h2 class="fw-bold text-color m-0">
            @* Hiển thị Icon và tên rạp từ biến cinema lấy ở trên *@
            <i class="bi bi-door-open-fill"></i> Quản lý Phòng: <span class="text-info">@cinema?.Name</span>
        </h2>

        <div>
            @* Quay lại danh sách rạp tổng quát *@
            <a asp-action="Cinema" class="btn btn-outline-light me-2">
                <i class="bi bi-arrow-left"></i> Về danh sách Rạp
            </a>
            @* Nút thêm phòng: Truyền cinemaId đi kèm để khi tạo xong, hệ thống biết phòng này thuộc về rạp nào *@
            <a asp-action="CreateRoom" asp-route-cinemaId="@cinema?.Id" class="btn btn-light fw-bold text-dark">
                <i class="bi bi-plus-lg"></i> Thêm Phòng Mới
            </a>
        </div>
    </div>

    @* --- PHẦN THÔNG BÁO (ALERTS) --- *@
    @* Hiển thị lỗi (ví dụ: không thể xóa phòng đang có suất chiếu) *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-bold" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @* Hiển thị thành công (ví dụ: Đã cập nhật thông tin phòng) *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* --- BẢNG DANH SÁCH PHÒNG --- *@
    <div class="table-responsive">
        <table class="table table-dark table-hover table-bordered align-middle text-center">
            <thead class="table-secondary text-dark">
                <tr>
                    <th style="width: 5%;">ID</th>
                    <th style="width: 25%;">Tên Phòng</th>
                    <th style="width: 15%;">Số lượng ghế</th>
                    <th style="width: 25%;">Trạng thái</th>
                    <th style="width: 15%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @* Kiểm tra nếu danh sách phòng không rỗng mới bắt đầu vẽ bảng *@
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">@item.Id</td>
                            <td class="text-start fw-bold text-info fs-5">@item.Name</td>
                            <td>@item.TotalSeats ghế</td>

                            @* LOGIC HIỂN THỊ TRẠNG THÁI (STATUS) *@
                            <td>
                                @if (item.Status == 1)
                                {
                                    <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle"></i> Đang hoạt động</span>
                                }
                                else if (item.Status == 2)
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-tools"></i> Đang bảo trì</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger px-3 py-2"><i class="bi bi-x-circle"></i> Dừng hoạt động</span>
                                }
                            </td>

                            @* CÁC NÚT THAO TÁC *@
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    @* Sửa: Dẫn đến trang EditRoom kèm ID phòng *@
                                    <a asp-action="EditRoom" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Sửa phòng">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    @* Xóa: Có cảnh báo confirm để tránh xóa nhầm dữ liệu quan trọng *@
                                    <a asp-action="DeleteRoom" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa phòng này? Toàn bộ lịch chiếu của phòng sẽ bị ảnh hưởng!');"
                                       title="Xóa phòng">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    @* Giao diện hiển thị khi rạp mới xây chưa có phòng nào *@
                    <tr>
                        <td colspan="5" class="text-center text-secondary py-5">
                            <i class="bi bi-door-closed fs-1 d-block mb-2"></i>
                            Rạp này hiện chưa có phòng chiếu nào. Hãy tạo phòng mới!
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>