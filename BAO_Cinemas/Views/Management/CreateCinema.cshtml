@model BAO_Cinemas.Models.Cinema

@{
    ViewData["Title"] = "Thêm Rạp Mới";
}

<div class="container bg-dark text-white p-4 mt-4 rounded shadow" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <h2 class="fw-bold text-color m-0">Thêm Rạp Mới</h2>
        <a asp-action="Cinema" class="btn btn-outline-light">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <form asp-action="CreateCinema" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold">Tên Rạp <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control bg-secondary text-white border-0" placeholder="VD: BAO Cinemas Cầu Giấy" required />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Address" class="form-label fw-bold">Địa chỉ chi tiết</label>
            <input asp-for="Address" class="form-control bg-secondary text-white border-0" placeholder="VD: Tầng 3, TTTM ABC, Hà Nội..." />
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Hotline" class="form-label fw-bold">Hotline liên hệ</label>
            <input asp-for="Hotline" class="form-control bg-secondary text-white border-0" placeholder="VD: 1900 1234" />
            <span asp-validation-for="Hotline" class="text-danger small"></span>
        </div>

        <div class="text-end border-top border-secondary pt-3">
            <button type="submit" class="btn btn-light fw-bold px-4 py-2 text-dark">
                <i class="bi bi-save"></i> Lưu Rạp Mới
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}