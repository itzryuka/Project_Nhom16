@model IEnumerable<BAO_Cinemas.Models.Movie>
@{
    ViewData["Title"] = "Kho Phim";
    // Mặc định nó sẽ lấy _Layout.cshtml có chứa Navbar
}

<div class="container-fluid bg-dark text-white min-vh-100 p-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">

        <div class="text-start" style="width: 25%;">
            <h2 class="fw-bold text-color m-0">Kho Phim</h2>
        </div>

        <div class="text-center" style="width: 50%;">
            <div class="input-group">
                <span class="input-group-text bg-secondary border-0 text-white"><i class="bi bi-search"></i></span>
                <input type="text" id="searchInput" class="form-control bg-secondary border-0 text-white" placeholder="Nhập tên phim để tìm nhanh...">
            </div>
        </div>

        <div class="text-end" style="width: 25%;">
            <a href="/" class="btn btn-outline-light">
                <i class="bi bi-arrow-return-left"></i> Quay lại
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-bold" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div id="movieList">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                // Thẻ data-title dùng để JS lấy tên phim ra lọc
                <div class="movie-row card mb-3 bg-secondary border-0 shadow-sm" data-title="@item.Title.ToLower()">
                    <div class="row g-0 align-items-center">

                        <div class="col-auto" style="width: 90px; height: 130px; padding: 5px;">
                            <img src="@item.PosterUrl" class="rounded"
                                 style="width: 100%; height: 100%; object-fit: cover; object-position: center;" alt="poster">
                        </div>

                        <div class="col px-4 text-light">
                            <h5 class="fw-bold text-color mb-1">@item.Title</h5>
                            <p class="mb-1 small">
                                <span class="badge bg-dark text-light me-2">@item.Genre</span>
                                <span><i class="bi bi-clock"></i> @item.Duration phút</span>
                            </p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center text-secondary py-5">
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#searchInput").on("keyup", function () {
                var value = $(this).val().toLowerCase(); // Lấy chữ người dùng gõ
                $(".movie-row").filter(function () {
                    // Kiểm tra xem tên phim (data-title) có chứa chữ vừa gõ không
                    $(this).toggle($(this).data("title").indexOf(value) > -1)
                });
            });
        });
    </script>
}

<style>
    /* Hiệu ứng mượt mà khi hover vào thanh phim */
    .movie-row {
        transition: all 0.2s ease-in-out;
    }

        .movie-row:hover {
            background-color: #495057 !important;
            transform: scale(1.01);
        }
</style>